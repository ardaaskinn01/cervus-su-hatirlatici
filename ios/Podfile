# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = '1'

# Flutter'ın standart yardımcı dosyasını dahil ediyoruz
require_relative '../Flutter/generated_podhelper.rb' if File.exist?('../Flutter/generated_podhelper.rb')

project 'Runner', {
  'Debug' => :debug,
  'Release' => :release,
  'Profile' => :profile,
}

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Kütüphaneleri yükle (Eğer yardımcı dosya varsa)
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__)) if defined?(flutter_install_all_ios_pods)
  
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    # Flutter'ın kendi eklediği ayarları koru
    flutter_additional_ios_build_settings(target) if defined?(flutter_additional_ios_build_settings)
    
    target.build_configurations.each do |config|
      # Minimum iOS versiyonu zorlaması
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      
      # Xcode 16.x "module interface" hatası için kesin çözüm
      config.build_settings['DEFINES_MODULE'] = 'NO'
      config.build_settings['SWIFT_INSTALL_OBJC_HEADER'] = 'NO'
    end
  end
end

