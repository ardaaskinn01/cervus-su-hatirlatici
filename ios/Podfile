# Podfile for Cervus Water Reminder
platform :ios, '15.0'

ENV['COCOAPODS_DISABLE_STATS'] = '1'

project 'Runner', {
  'Debug' => :debug,
  'Release' => :release,
  'Profile' => :profile,
}

# Flutter SDK yolunu bulmak için daha esnek bir yöntem
def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  
  # Dosya yoksa hemen hata verme, önce bir bak bakalım içerde ne var
  if File.exist?(generated_xcode_build_settings_path)
    File.foreach(generated_xcode_build_settings_path) do |line|
      matches = line.match(/\AFLUTTER_ROOT=(.*)\z/)
      return matches[1].strip if matches
    end
  end
  
  # Eğer bulunamazsa veya dosya yoksa, ortam değişkenini dene (CI için)
  ENV['FLUTTER_ROOT'] || (raise "FLUTTER_ROOT not found. Run 'flutter pub get' first.")
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper.rb'), flutter_root)

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      # --- KESİN ÇÖZÜM: XCODE 16 / 26 MODÜL FIX ---
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'NO'
      config.build_settings['SWIFT_INSTALL_OBJC_HEADER'] = 'YES'
      config.build_settings['GCC_PRECOMPILE_PREFIX_HEADER'] = 'NO'
      # ---------------------------------------------
    end
  end
end
